generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Design {
  id                String            @id @default(cuid())
  notionId          String?           @unique
  designCode        String            @unique
  designName        String
  designType        String?
  styleFamily       String?
  collections       String?
  colorTags         String?
  inductionFriendly Boolean           @default(false)
  circleFriendly    Boolean           @default(false)
  splashFriendly    Boolean           @default(false)
  notionData        String?
  status            String            @default("DRAFT")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  driveFileId       String?
  driveFileName     String?
  content           Content[]
  mockups           DesignMockup[]
  printFiles        DesignPrintFile[]
  variants          Variant[]
  workflowSteps     WorkflowStep[]

  @@index([designCode])
  @@index([status])
}

model Variant {
  id               String   @id @default(cuid())
  designId         String
  productType      String
  size             String
  sku              String   @unique
  ean              String?
  gs1Registered    Boolean  @default(false)
  shopifyProductId String?
  shopifyVariantId String?
  price            Float?
  weight           Float?
  printFilePath    String?
  mockupFilePath   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  material         String?
  design           Design   @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId])
  @@index([sku])
  @@index([ean])
}

model Content {
  id                        String   @id @default(cuid())
  designId                  String
  language                  String
  description               String?
  altText                   String?
  seoTitle                  String?
  seoDescription            String?
  translatedFrom            String?
  translationStatus         String   @default("PENDING")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  longDescription           String?
  googleShoppingDescription String?
  design                    Design   @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@unique([designId, language])
  @@index([designId])
}

model WorkflowStep {
  id          String    @id @default(cuid())
  designId    String
  step        String
  status      String    @default("PENDING")
  data        String?
  error       String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  design      Design    @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@unique([designId, step])
  @@index([designId])
}

model DesignMockup {
  id          String   @id @default(cuid())
  designId    String
  templateId  String
  outputName  String
  productType String
  driveFileId String
  driveUrl    String
  createdAt   DateTime @default(now())
  altText     String?
  sizeKey     String?
  design      Design   @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId])
}

model DesignPrintFile {
  id          String   @id @default(cuid())
  designId    String
  productType String
  sizeKey     String
  widthMM     Int
  heightMM    Int
  fileName    String
  driveFileId String
  driveUrl    String
  createdAt   DateTime @default(now())
  design      Design   @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@unique([designId, sizeKey])
  @@index([designId])
}

model ApiKey {
  id        String    @id @default(cuid())
  name      String    @unique
  key       String    @unique
  service   String
  createdAt DateTime  @default(now())
  expiresAt DateTime?
}

model SyncLog {
  id        String   @id @default(cuid())
  source    String
  action    String
  entity    String
  entityId  String
  status    String
  details   String?
  createdAt DateTime @default(now())
}

model BrandVoice {
  id                   String   @id @default(cuid())
  key                  String   @unique
  companyInfo          String?
  mission              String?
  targetAudience       String?
  partnerInfo          String?
  materialIB           String?
  materialMC           String?
  materialSP           String?
  toneOfVoice          String?
  doUse                String?
  doNotUse             String?
  seoKeywordsIB        String?
  seoKeywordsMC        String?
  seoKeywordsSP        String?
  exampleDescriptionIB String?
  exampleDescriptionMC String?
  exampleDescriptionSP String?
  faq                  String?
  updatedAt            DateTime @updatedAt
}
